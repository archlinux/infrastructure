listen {{ ipv4_address ~ ':' if nginx_explict_listen_addresses }}443 ssl{{ ' proxy_protocol' if nginx_proxy_protocol_host }};
listen [{{ ipv6_address if nginx_explict_listen_addresses else '::' }}]:443{{ ' proxy_protocol' if nginx_proxy_protocol_host }};
{% if nginx_enable_http3 %}
listen {{ ipv4_address ~ ':' if nginx_explict_listen_addresses }}443 quic;
listen [{{ ipv6_address if nginx_explict_listen_addresses else '::' }}]:443 quic;
{% endif %}
http2 on;
{% if nginx_proxy_protocol_host %}
set_real_ip_from {{ nginx_proxy_protocol_host }};
