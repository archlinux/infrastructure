server {
    listen       80 default_server{{ ' proxy_protocol' if nginx_proxy_protocol_upstream_host or nginx_proxy_vendor }};
    listen       [::]:80 default_server{{ ' proxy_protocol' if nginx_proxy_protocol_upstream_host or nginx_proxy_vendor }};

    listen       443 default_server ssl{{ ' proxy_protocol' if nginx_proxy_protocol_upstream_host or nginx_proxy_vendor }};
    listen       [::]:443 default_server ssl{{ ' proxy_protocol' if nginx_proxy_protocol_upstream_host or nginx_proxy_vendor }};
{% if nginx_enable_http3 %}
    listen       443 default_server quic reuseport;
    listen       [::]:443 default_server quic reuseport;
{% endif %}
    http2        on;
    ssl_reject_handshake on;
    root         /srv/http;

    include snippets/letsencrypt.conf;

    location / {
        return 404;
    }
}
